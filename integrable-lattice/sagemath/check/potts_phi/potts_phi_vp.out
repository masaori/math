#### q=3, L=3, x=2 ; dim=27
   Z_N(1..6)=[528, 40428, 5131452, 761355108, 119523791628, 19194984322020]
   Φ_1=4*l_2 + 1*l_3 + 1*l_11, Φ_2=2*l_2 + 2*l_3 + 1*l_1123, Φ_3=2*l_2 + 1*l_3 + 1*l_427621
