======================================================================
3-状態 Potts: Z_{N,L}=Tr T^N, Φ_N∈Λ, v_p 則の普遍性
======================================================================

#### q=3, L=2, x=2 ; dim=9
   Z_N(1..6)=[72, 1458, 40428, 1248498, 40193172, 1315237914]
   Φ_1=3*l_2 + 2*l_3, Φ_2=1*l_2 + 6*l_3, Φ_3=2*l_2 + 2*l_3 + 1*l_1123
   p=2: μ_min=0, v_p[1..10]=[3, 1, 2, 1, 2, 1, 2, 1, 2, 1], 残差最終周期=2 =>予想成立=True
   p=3: μ_min=0, v_p[1..10]=[2, 6, 2, 2, 5, 2, 2, 5, 2, 2], 残差最終周期=None =>予想成立=False

#### q=3, L=2, x=3 ; dim=9
